      },
      "oauth": {
        "authorizationUrl": "https://mcp.datadoghq.com/api/unstable/mcp-server/authorize",
        "tokenUrl": "https://mcp.datadoghq.com/api/unstable/mcp-server/token",
        "registrationUrl": "https://mcp.datadoghq.com/api/unstable/mcp-server/register",
        "clientId": "mcp_0767ad8413142a20552eadacf5ed1b82"
      }
