{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "lifecycle": "lazy",
      "idleTimeout": 30
    },
    "contextplus": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "contextplus"
      ],
      "env": {
        "OLLAMA_HOST": "http://127.0.0.1:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "OLLAMA_CHAT_MODEL": "qwen2.5-coder:7b",
        "CONTEXTPLUS_EMBED_BATCH_SIZE": "8",
        "CONTEXTPLUS_EMBED_TRACKER": "true"
      },
      "lifecycle": "lazy",
      "idleTimeout": 30
    },
    "datadog": {
      "type": "http",
